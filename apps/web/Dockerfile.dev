# Node 22 LTS Alpine — required by Next.js 16, React 19, TypeScript 7
FROM node:22-alpine

WORKDIR /app

# Install dependencies only (separate layer for better caching)
COPY package*.json ./
RUN npm install

# Copy source code (node_modules excluded via .dockerignore)
COPY . .

EXPOSE 3000

# Development server with hot-reload
CMD ["npm", "run", "dev"]
